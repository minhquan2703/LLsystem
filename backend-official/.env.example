PORT=

# Database (Supabase PostgreSQL — dùng Session Pooler, không phải Transaction Pooler)
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=postgres

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRED=
JWT_REFRESH_SECRET=
JWT_REFRESH_TOKEN_EXPIRED=

# Mail (Gmail SMTP)
MAIL_USER=
MAIL_PASSWORD=

# Gemini
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_SPEAKING_MODEL=gemini-3.1-flash

# Supabase Storage (speaking audio)
# SUPABASE_URL: lấy từ Supabase Dashboard → Project Settings → API → Project URL
# SUPABASE_SERVICE_ROLE_KEY: lấy từ Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SPEAKING_BUCKET=speaking-audio
