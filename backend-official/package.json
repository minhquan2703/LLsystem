{
  "name": "02-nest-rn",
  "version": "0.0.1",
  "description": "",
  "author": {
    "name": "LLsystem"
  },
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "prosody:setup": "cd ../prosody-service && python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt",
    "prosody:dev": "cd ../prosody-service && .venv\\Scripts\\uvicorn main:app --reload --port 8001",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "import:cedict": "ts-node -r tsconfig-paths/register src/scripts/import-cedict.ts",
    "fill:hanviet": "ts-node -r tsconfig-paths/register src/scripts/fill-hanviet.ts",
    "fill:viet": "ts-node -r tsconfig-paths/register src/scripts/fill-vietnamese-def.ts",
    "fill:hsk": "ts-node -r tsconfig-paths/register src/scripts/fill-hsk-level.ts",
    "seed:topics": "ts-node -r tsconfig-paths/register src/scripts/seed-topics.ts",
    "seed:speaking": "ts-node -r tsconfig-paths/register src/scripts/seed-speaking-questions.ts",
    "seed:english-words": "ts-node -r tsconfig-paths/register src/scripts/seed-english-words.ts",
    "fill:topics": "ts-node -r tsconfig-paths/register src/scripts/fill-topics.ts",
    "cleanup:topic": "ts-node -r tsconfig-paths/register src/scripts/cleanup-topic.ts",
    "enrich:gemini": "ts-node -r tsconfig-paths/register src/scripts/enrich-words-gemini.ts",
    "normalize:pinyin": "ts-node -r tsconfig-paths/register src/scripts/normalize-pinyin.ts",
    "translate:examples": "ts-node -r tsconfig-paths/register src/scripts/translate-examples.ts",
    "explain:implementations": "ts-node -r tsconfig-paths/register src/scripts/explain-implementations-gemini.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs-modules/mailer": "2.0.2",
    "@nestjs/common": "10.3.10",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.3.10",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/mapped-types": "2.0.5",
    "@nestjs/mongoose": "10.0.10",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.3.10",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@supabase/supabase-js": "^2.108.1",
    "api-query-params": "5.4.0",
    "bcrypt": "5.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "dayjs": "1.11.12",
    "handlebars": "4.7.8",
    "hanviet-pinyin-words": "^2.1.7",
    "mongoose": "8.5.1",
    "nodemailer": "6.9.14",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "^8.21.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "^1.0.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.2",
    "@nestjs/schematics": "10.1.3",
    "@nestjs/testing": "10.3.10",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.12",
    "@types/nodemailer": "6.4.15",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "7.17.0",
    "@typescript-eslint/parser": "7.17.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.3",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
